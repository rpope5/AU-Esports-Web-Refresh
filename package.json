{
  "name": "au-esports-platform",
  "private": true,
  "scripts": {
    "install:web": "npm --prefix apps/web install",
    "dev:web": "npm --prefix apps/web run dev",
    "lint:web": "npm --prefix apps/web run lint",
    "build:web": "npm --prefix apps/web run build",
    "install:api": "powershell -NoProfile -ExecutionPolicy Bypass -File infra/scripts/api_install.ps1",
    "dev:api": "powershell -NoProfile -ExecutionPolicy Bypass -File infra/scripts/api_dev.ps1",
    "dev": "concurrently -n API,WEB \"npm run dev:api\" \"npm run dev:web\""

  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
