# API (shared baseline)
APP_ENV=development
APP_NAME=AU Esports Platform API
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./dev.db
AUTO_CREATE_TABLES=false
RUN_DB_MIGRATIONS_ON_STARTUP=false

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://localhost:3000,https://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

JWT_SECRET=replace_with_long_random_secret
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=120

ENABLE_DEBUG_ROUTES=false

# Media storage: local (dev) or azure_blob (production-ready)
MEDIA_BACKEND=local
UPLOADS_ROOT=
MEDIA_AZURE_BLOB_CONNECTION_STRING=
MEDIA_AZURE_BLOB_CONTAINER=au-esports-media
NEWS_IMAGE_MAX_UPLOAD_BYTES=5242880
ROSTER_HEADSHOT_MAX_UPLOAD_BYTES=5242880

# Optional Azure Graph integration
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_GROUP_ID=
REDIRECT_URI=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

